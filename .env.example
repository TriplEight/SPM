# SPM — environment variables template
# Copy to .env and fill in real values

# Algorand network (TestNet)
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
ALGOD_PORT=443

# SplitRouter app (set after deployment)
SPLIT_APP_ID=
SPLIT_APP_ADDRESS=

# Payer wallet (MCP server — fund with ALGO + USDC on TestNet)
PAYER_MNEMONIC=

# Proxy config
PORT=4873
SQLITE_PATH=./audit.db
SPM_PROXY_URL=http://localhost:4873

# Contract deployment accounts (from genaccounts.ts)
PAYER_ADDR=
AUDITOR_ADDR=
AUDITOR_MNEMONIC=
MAINTAINER_ADDR=
MAINTAINER_MNEMONIC=
ADVERSARIAL_ADDR=
ADVERSARIAL_MNEMONIC=
TREASURY_ADDR=
TREASURY_MNEMONIC=
OPS_ADDR=
OPS_MNEMONIC=
